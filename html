<!-- index.html -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- SEO Meta Tags -->
  <meta name="description" content="Personal Portfolio Website">
  <meta name="keywords" content="Portfolio, Web Developer, HTML5, CSS3">
  <meta name="author" content="Tharun">

  <title>My Portfolio</title>

  <link rel="stylesheet" href="style.css">
</head>

<body>

  <!-- Skip Link -->
  <a href="#main-content" class="skip-link">
    Skip to Main Content
  </a>

  <!-- Header -->
  <header>
    <nav aria-label="Main Navigation">
      <h1>Tharun Portfolio</h1>

      <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <!-- Main Content -->
  <main id="main-content">

    <!-- Hero Section -->
    <section class="hero">
      <h2>Hello, I'm Tharun</h2>
      <p>Web Development Intern | Frontend Developer</p>
    </section>

    <!-- About Section -->
    <section id="about">
      <h2>About Me</h2>

      <article>
        <p>
          I am passionate about web development and creating
          accessible, user-friendly websites using modern HTML5 and CSS3.
        </p>
      </article>
    </section>

    <!-- Projects Section -->
    <section id="projects">
      <h2>Projects</h2>

      <article class="project-card">
        <h3>Portfolio Website</h3>
        <p>
          Responsive personal portfolio website using semantic HTML5 and CSS3.
        </p>
      </article>

      <article class="project-card">
        <h3>Landing Page</h3>
        <p>
          SEO-friendly landing page with accessibility features.
        </p>
      </article>
    </section>

    <!-- Contact Section -->
    <section id="contact">
      <h2>Contact Me</h2>

      <form aria-label="Contact Form">

        <div class="form-group">
          <label for="name">Name</label>

          <input
            type="text"
            id="name"
            name="name"
            required
          >
        </div>

        <div class="form-group">
          <label for="email">Email</label>

          <input
            type="email"
            id="email"
            name="email"
            required
          >
        </div>

        <div class="form-group">
          <label for="message">Message</label>

          <textarea
            id="message"
            name="message"
            rows="5"
            required
          ></textarea>
        </div>

        <button type="submit">
          Send Message
        </button>

      </form>
    </section>

  </main>

  <!-- Sidebar -->
  <aside>
    <h2>Skills</h2>

    <ul>
      <li>HTML5</li>
      <li>CSS3</li>
      <li>JavaScript</li>
    </ul>
  </aside>

  <!-- Footer -->
  <footer>
    <p>&copy; 2026 Tharun Portfolio. All Rights Reserved.</p>
  </footer>

</body>
</html>
